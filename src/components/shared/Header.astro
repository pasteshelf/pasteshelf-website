---
const navLinks = [
  { label: 'Features', href: '#features' },
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Download', href: '#download' },
  { label: 'FAQ', href: '#faq' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-slate-100">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <img src="/icon.png" alt="PasteShelf" class="w-9 h-9 rounded-lg shadow-sm group-hover:scale-105 transition-transform" />
      <span class="text-xl font-bold text-slate-900">PasteShelf</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-slate-600 hover:text-coral-600 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/pasteshelf/PasteShelf"
        target="_blank"
        rel="noopener"
        class="text-sm font-medium text-slate-600 hover:text-coral-600 transition-colors"
      >
        GitHub
      </a>
      <a
        href="https://github.com/pasteshelf/PasteShelf/releases/latest"
        data-download-dmg
        class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-coral-500 rounded-lg hover:bg-coral-600 transition-colors shadow-sm"
      >
        Download
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-slate-600 hover:text-slate-900"
      aria-expanded="false"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 px-6 pb-4">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block py-3 text-sm font-medium text-slate-600 hover:text-coral-600 border-b border-slate-50"
      >
        {link.label}
      </a>
    ))}
    <a
      href="https://github.com/pasteshelf/PasteShelf"
      target="_blank"
      rel="noopener"
      class="block py-3 text-sm font-medium text-slate-600 hover:text-coral-600 border-b border-slate-50"
    >
      GitHub
    </a>
    <a
      href="https://github.com/pasteshelf/PasteShelf/releases/latest"
      data-download-dmg
      class="mt-3 block text-center px-4 py-2.5 text-sm font-semibold text-white bg-coral-500 rounded-lg"
    >
      Download
    </a>
  </div>
</header>
