---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-300">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img src="/icon.png" alt="PasteShelf" class="w-10 h-10 rounded-xl" />
          <span class="text-lg font-bold text-white">PasteShelf</span>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed">
          Privacy-first clipboard manager for macOS. Open-source under AGPL-3.0.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="#features" class="text-sm hover:text-coral-400 transition-colors">Features</a></li>
          <li><a href="#how-it-works" class="text-sm hover:text-coral-400 transition-colors">How It Works</a></li>
          <li><a href="#download" class="text-sm hover:text-coral-400 transition-colors">Download</a></li>
          <li><a href="#faq" class="text-sm hover:text-coral-400 transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Resources</h4>
        <ul class="space-y-2.5">
          <li><a href="https://github.com/pasteshelf/PasteShelf" target="_blank" rel="noopener" class="text-sm hover:text-coral-400 transition-colors">GitHub</a></li>
          <li><a href="https://github.com/pasteshelf/PasteShelf/issues" target="_blank" rel="noopener" class="text-sm hover:text-coral-400 transition-colors">Report a Bug</a></li>
          <li><a href="https://github.com/pasteshelf/PasteShelf/blob/main/docs/contributing/CONTRIBUTING.md" target="_blank" rel="noopener" class="text-sm hover:text-coral-400 transition-colors">Contributing</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-2.5">
          <li><a href="https://github.com/pasteshelf/PasteShelf/blob/main/LICENSE" target="_blank" rel="noopener" class="text-sm hover:text-coral-400 transition-colors">License (AGPL-3.0)</a></li>
          <li><a href="https://github.com/pasteshelf/PasteShelf/blob/main/docs/PRIVACY.md" target="_blank" rel="noopener" class="text-sm hover:text-coral-400 transition-colors">Privacy Policy</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500">&copy; {currentYear} PasteShelf. All rights reserved.</p>
      <p class="text-sm text-slate-500">Made with care for macOS users.</p>
    </div>
  </div>
</footer>
