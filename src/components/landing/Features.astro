---
const features = [
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>',
    title: 'Unlimited History',
    description: 'Never lose copied content again. Text, images, files, URLs, code snippets — all captured automatically.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>',
    title: 'Instant Search',
    description: 'Full-text search with fuzzy matching across all clipboard items. Find anything in milliseconds.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>',
    title: 'Privacy First',
    description: 'All data stored locally on your Mac. No cloud, no analytics, no telemetry. Your clipboard stays yours.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>',
    title: 'Smart Categories',
    description: 'Auto-organize by content type — text, images, files, code. Create custom collections with rules.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>',
    title: 'Global Hotkey',
    description: 'Press ⌘⇧V anywhere to instantly access your clipboard history. Keyboard-first workflow.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>',
    title: 'OCR Search',
    description: 'Find text within copied images. Optical character recognition makes every screenshot searchable.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/>',
    title: 'iCloud Sync',
    description: 'Optional encrypted sync across all your Macs. End-to-end encrypted — not even Apple can read it.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/>',
    title: 'Automation & Plugins',
    description: 'Shortcuts, AppleScript, webhooks. Extend with community plugins for limitless workflows.',
  },
];
---

<section id="features" class="pt-16 pb-20 md:pt-20 md:pb-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div data-animate class="text-center mb-16">
      <span class="inline-block text-sm font-semibold text-coral-500 uppercase tracking-wider mb-3">Features</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Everything you need from a clipboard manager</h2>
      <p class="mt-4 text-lg text-slate-500 max-w-2xl mx-auto">All features are free and open-source. No premium tiers, no subscriptions.</p>
    </div>

    <div data-animate-stagger class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature) => (
        <div class="group p-6 rounded-2xl border border-slate-100 bg-white hover:border-coral-200 hover:bg-coral-50/30 transition-all duration-300">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-coral-50 text-coral-500 group-hover:bg-coral-100 transition-colors mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={feature.icon} />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">{feature.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
