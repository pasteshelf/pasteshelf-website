---
const steps = [
  {
    number: '1',
    title: 'Copy Anything',
    description: 'Use your Mac normally. Every time you copy text, images, files, or code — PasteShelf captures it silently in the background.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>',
  },
  {
    number: '2',
    title: 'Search & Browse',
    description: 'Press ⌘⇧V to open PasteShelf. Browse by date, filter by type, or search with fuzzy matching to find exactly what you need.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>',
  },
  {
    number: '3',
    title: 'Paste Instantly',
    description: 'Select any item and it goes straight to your clipboard — ready to paste. Or use quick-paste to insert directly into any app.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>',
  },
];
---

<section id="how-it-works" class="pt-16 pb-20 md:pt-20 md:pb-28 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <div data-animate class="text-center mb-16">
      <span class="inline-block text-sm font-semibold text-coral-500 uppercase tracking-wider mb-3">How It Works</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Three steps. Zero friction.</h2>
      <p class="mt-4 text-lg text-slate-500">Simple by design. Powerful when you need it.</p>
    </div>

    <div data-animate-stagger class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {steps.map((step) => (
        <div class="relative text-center">
          <!-- Step number -->
          <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center rounded-2xl bg-coral-500 text-white shadow-lg shadow-coral-500/20">
            <span class="text-xl font-bold">{step.number}</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">{step.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
