<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
  <!-- Soft gradient background -->
  <div class="absolute inset-0 bg-gradient-to-b from-coral-50/60 via-white to-white pointer-events-none"></div>
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-coral-200/20 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <!-- App Icon -->
    <div data-animate class="mb-8">
      <img
        src="/icon.png"
        alt="PasteShelf"
        class="w-28 h-28 mx-auto rounded-[1.75rem] shadow-xl glow-coral"
      />
    </div>

    <!-- Headline -->
    <h1 data-animate class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-slate-900 leading-[1.1]">
      Your clipboard,<br />
      <span class="text-gradient">your control.</span>
    </h1>

    <!-- Subtitle -->
    <p data-animate class="mt-6 text-lg md:text-xl text-slate-500 max-w-2xl mx-auto leading-relaxed">
      A privacy-first clipboard manager for macOS. Unlimited history, instant search, zero cloud — everything stays on your Mac.
    </p>

    <!-- CTA buttons -->
    <div data-animate class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://github.com/pasteshelf/PasteShelf/releases/latest"
        data-download-dmg
        class="inline-flex items-center px-7 py-3.5 text-base font-semibold text-white bg-coral-500 rounded-xl hover:bg-coral-600 transition-all shadow-lg shadow-coral-500/25 hover:shadow-coral-500/40 hover:-translate-y-0.5"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Download for Free
      </a>
      <a
        href="https://github.com/pasteshelf/PasteShelf"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center px-7 py-3.5 text-base font-semibold text-slate-700 bg-white border border-slate-200 rounded-xl hover:border-slate-300 hover:bg-slate-50 transition-all"
      >
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Brew install -->
    <div data-animate class="mt-10 inline-flex items-center gap-3 bg-slate-900 text-slate-300 px-5 py-3 rounded-xl text-sm font-mono">
      <span class="text-slate-500">$</span>
      <code>brew install --cask pasteshelf/pasteshelf/pasteshelf</code>
      <button
        id="copy-brew"
        class="text-slate-500 hover:text-white transition-colors"
        aria-label="Copy command"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </button>
    </div>
  </div>

  <script>
    document.getElementById('copy-brew')?.addEventListener('click', function() {
      navigator.clipboard.writeText('brew install --cask pasteshelf/pasteshelf/pasteshelf');
      const btn = document.getElementById('copy-brew');
      if (btn) {
        const svg = btn.querySelector('svg');
        if (svg) {
          svg.setAttribute('class', 'w-4 h-4 text-green-400');
          const path = svg.querySelector('path');
          if (path) {
            path.setAttribute('d', 'M5 13l4 4L19 7');
          }
          setTimeout(function() {
            svg.setAttribute('class', 'w-4 h-4');
            if (path) {
              path.setAttribute('d', 'M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z');
            }
          }, 2000);
        }
      }
    });
  </script>
</section>
